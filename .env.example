# mBER custom weight locations
# Edit these paths to point to a disk with enough free space, then load with:
#   set -a
#   source .env
#   set +a

# Preferred: one shared root directory for all weights
# export MBER_WEIGHTS_DIR=/path/to/large-disk/mber_weights

# Optional: override individual locations instead of using one shared root
# export MBER_AF_PARAMS_DIR=/path/to/large-disk/mber_weights/af_params
# export MBER_NBB2_WEIGHTS_DIR=/path/to/large-disk/mber_weights/nbb2_weights
# export MBER_HF_HOME=/path/to/large-disk/mber_weights/huggingface

export MBER_AF_PARAMS_DIR=/scratch2/mz32/zhaorui/weight/mber_weights/af_params
export MBER_NBB2_WEIGHTS_DIR=/scratch2/mz32/zhaorui/weight/mber_weights/nbb2_weights
export MBER_HF_HOME=/scratch2/mz32/zhaorui/weight/mber_weights/huggingface
